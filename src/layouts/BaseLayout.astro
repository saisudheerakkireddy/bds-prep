---
import "../styles/global.css";
import AuthHeader from "../components/AuthHeader";
import ProgressSync from "../components/ProgressSync";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "BDS Final Year Exam Prep — Andhra Pradesh 2026" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <title>{title} | BDS Prep AP 2026</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="background-elements">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>

    <header class="sticky top-0 z-50 glassmorphism border-b border-[var(--border-color)] rounded-none header-sticky-layer">
      <nav class="container-tight flex items-center justify-between h-16">
        <a href="/" class="flex items-center gap-2 font-bold text-lg" style="color: var(--text-primary);">
          <span class="text-2xl">🦷</span>
          <span class="hidden sm:inline">BDS Prep</span>
          <span class="badge-subject">AP 2026</span>
        </a>
        <div class="flex items-center gap-1 sm:gap-4">
          <a
            href="/"
            class="px-3 py-2 text-sm font-medium rounded-lg transition-colors"
            style="color: var(--text-secondary);"
          >
            Home
          </a>
          <a
            href="/planner"
            class="px-3 py-2 text-sm font-medium rounded-lg transition-colors"
            style="color: var(--text-secondary);"
          >
            Planner
          </a>
          <AuthHeader client:load />
        </div>
      </nav>
    </header>

    <ProgressSync client:load />
    <main id="main-content" class="flex-1" tabindex="-1">
      <slot />
    </main>

    <footer class="border-t mt-16 py-8" style="border-color: var(--border-color); background: var(--glass-bg);">
      <div class="container-tight text-center text-sm" style="color: var(--text-secondary);">
        <p>Built with care for BDS Final Year students, AP.</p>
        <p class="mt-1">Not affiliated with any university. For study purposes only.</p>
      </div>
    </footer>
  </body>
</html>
